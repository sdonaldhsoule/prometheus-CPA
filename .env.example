# 数据库配置
DATABASE_URL=postgres://donation:donation123@localhost:5432/donation_station?sslmode=disable

# 服务端口
PORT=8080

# CPA配置（必填）
# 你的CLIProxyAPI服务地址
CPA_BASE_URL=https://your-cpa-server.com
# CPA的管理密钥（在CPA配置中设置的 management-secret-key 或 MANAGEMENT_PASSWORD 环境变量）
CPA_MANAGEMENT_KEY=your-cpa-management-key

# NewAPI 配置（必填，用于用户登录）
NEWAPI_BASE_URL=https://your-newapi-server.com

# 回调配置 (CDK生成后的回调地址，可选)
CALLBACK_URL=
CALLBACK_SECRET=your-callback-secret-change-me

# 安全密钥
JWT_SECRET=your-jwt-secret-change-me

# CDK配置
CDK_PREFIX=DS

# 站点配置
SITE_NAME=凭证捐赠站
BACKGROUND_IMAGE=

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
